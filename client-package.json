:root{
  --bg:#050b14;
  --panel:#0b1626;
  --panel-2:#0f1d31;
  --line:#1c304b;
  --text:#edf6ff;
  --muted:#8ea4bf;
  --cyan:#33d6ff;
  --cyan-2:#0ea5e9;
  --green:#46e6a6;
  --amber:#ffbf48;
  --orange:#ff814a;
  --red:#ff4d6d;
  --purple:#9f7aea;
  --shadow:0 20px 60px rgba(0,0,0,.28);
}
*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;background:radial-gradient(circle at 80% 0%,rgba(14,165,233,.12),transparent 28%),var(--bg);color:var(--text);font-family:Inter,Segoe UI,Arial,sans-serif;min-height:100vh}
button,input,select{font:inherit}
button{cursor:pointer}
.app-shell{display:grid;grid-template-columns:264px minmax(0,1fr);min-height:100vh}
.sidebar{position:sticky;top:0;height:100vh;padding:24px 18px;border-right:1px solid var(--line);background:rgba(5,11,20,.94);backdrop-filter:blur(18px);display:flex;flex-direction:column;z-index:10}
.brand{display:flex;align-items:center;gap:12px;padding:0 8px 24px;border-bottom:1px solid var(--line)}
.brand-mark{width:42px;height:42px}
.brand-mark svg{fill:rgba(51,214,255,.18);stroke:var(--cyan);stroke-width:2.4}
.brand-mark .brand-mark-inner{fill:none;stroke:#fff;stroke-width:4;stroke-linecap:round;stroke-linejoin:round}
.brand strong{font-family:Segoe UI,Arial,sans-serif;font-size:18px;letter-spacing:.5px;display:block}
.brand span{font-size:11px;color:var(--muted)}
.nav{display:flex;flex-direction:column;gap:8px;margin-top:24px}
.nav-item{border:0;background:transparent;color:var(--muted);text-align:left;padding:13px 14px;border-radius:12px;display:flex;gap:12px;align-items:center;font-weight:700;transition:.2s}
.nav-item span{font-size:18px;width:22px;text-align:center}
.nav-item:hover,.nav-item.active{color:#fff;background:linear-gradient(90deg,rgba(51,214,255,.16),rgba(51,214,255,.04));box-shadow:inset 3px 0 var(--cyan)}
.sidebar-card{display:flex;align-items:center;gap:10px;margin-top:auto;padding:13px;border:1px solid rgba(70,230,166,.25);background:rgba(70,230,166,.07);border-radius:12px}
.sidebar-card strong{display:block;font-size:12px}
.sidebar-card span{font-size:10px;color:var(--muted)}
.pulse-dot{width:9px;height:9px;border-radius:50%;background:var(--green);box-shadow:0 0 0 0 rgba(70,230,166,.6);animation:pulse 1.8s infinite}
@keyframes pulse{70%{box-shadow:0 0 0 10px rgba(70,230,166,0)}100%{box-shadow:0 0 0 0 rgba(70,230,166,0)}}
.privacy-note{padding:16px 10px 0;color:var(--muted);font-size:11px}
.privacy-note strong{color:#dbeafe}
.privacy-note p{margin:5px 0 0;line-height:1.5}

.main{padding:26px 30px 110px;min-width:0}
.topbar{display:flex;justify-content:space-between;align-items:center;gap:20px;margin-bottom:22px}
.eyebrow{margin:0 0 5px;text-transform:uppercase;letter-spacing:1.3px;color:var(--cyan);font-size:10px;font-weight:800}
h1,h2,h3,p{margin-top:0}
h1{font-family:Segoe UI,Arial,sans-serif;font-size:28px;margin-bottom:0}
h2{font-size:17px;margin-bottom:0}
.top-actions{display:flex;align-items:center;gap:10px}
.ghost-btn,.primary-btn,.text-btn,.mini-toggle,.pagination button{border-radius:10px;padding:10px 14px;border:1px solid var(--line);font-weight:700}
.ghost-btn{background:var(--panel);color:var(--text)}
.primary-btn{background:linear-gradient(135deg,var(--cyan),var(--cyan-2));color:#02101a;border:0}
.avatar{width:38px;height:38px;display:grid;place-items:center;border-radius:50%;background:linear-gradient(135deg,#164e63,#0ea5e9);font-weight:800;border:1px solid rgba(255,255,255,.2)}
.control-strip{display:grid;grid-template-columns:repeat(4,minmax(145px,1fr)) auto;gap:12px;align-items:end;background:rgba(11,22,38,.72);border:1px solid var(--line);padding:14px;border-radius:16px;margin-bottom:18px}
.control-strip label span{display:block;color:var(--muted);font-size:10px;font-weight:700;margin:0 0 6px 4px;text-transform:uppercase}
select,.search-box input,#askInput{width:100%;color:var(--text);background:#07111f;border:1px solid var(--line);border-radius:10px;padding:10px 12px;outline:none}
select:focus,input:focus{border-color:var(--cyan);box-shadow:0 0 0 3px rgba(51,214,255,.08)}
.data-badge{display:flex;align-items:center;gap:7px;padding:10px 12px;color:var(--muted);font-size:11px;white-space:nowrap}
.data-badge span{width:8px;height:8px;border-radius:50%;background:var(--green)}
.data-badge strong{color:#fff}

.view{display:none;animation:fade .25s ease}
.view.active{display:block}
@keyframes fade{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:none}}
.metric-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:12px;margin-bottom:14px}
.metric-card{background:linear-gradient(145deg,rgba(15,29,49,.95),rgba(8,18,31,.95));border:1px solid var(--line);border-radius:15px;padding:15px;min-height:112px;position:relative;overflow:hidden}
.metric-card:after{content:"";position:absolute;width:75px;height:75px;border-radius:50%;right:-25px;bottom:-30px;background:var(--metric-color);opacity:.1}
.metric-icon{width:32px;height:32px;border-radius:9px;display:grid;place-items:center;background:color-mix(in srgb,var(--metric-color) 15%,transparent);color:var(--metric-color);font-weight:800;margin-bottom:12px}
.metric-value{font-family:Segoe UI,Arial,sans-serif;font-size:24px;font-weight:700}
.metric-label{font-size:10px;color:var(--muted);margin-top:3px}
.metric-trend{position:absolute;right:12px;top:14px;font-size:10px;color:var(--green);font-weight:800}

.grid{display:grid;gap:14px;margin-bottom:14px}
.two-one{grid-template-columns:2fr 1fr}
.equal{grid-template-columns:1fr 1fr}
.panel{background:linear-gradient(145deg,rgba(15,29,49,.94),rgba(8,18,31,.96));border:1px solid var(--line);border-radius:16px;padding:17px;box-shadow:var(--shadow)}
.panel-head{display:flex;justify-content:space-between;align-items:flex-start;gap:12px;margin-bottom:14px}
.confidence-pill,.privacy-chip{border:1px solid rgba(70,230,166,.28);background:rgba(70,230,166,.08);color:var(--green);font-size:10px;padding:7px 9px;border-radius:999px;font-weight:800}
canvas{width:100%;display:block}
.chart-legend{display:flex;justify-content:center;gap:22px;color:var(--muted);font-size:10px;margin-top:8px}
.chart-legend i,.donut-legend i{display:inline-block;width:16px;height:3px;border-radius:4px;margin-right:6px;vertical-align:middle}
.legend-actual{background:var(--cyan)}
.legend-forecast{background:var(--purple);border-top:1px dashed #fff}
.risk-status{font-size:10px;padding:7px 10px;border-radius:8px;background:rgba(255,77,109,.12);color:var(--red);font-weight:900;letter-spacing:1px}
.risk-ring-wrap{display:flex;align-items:center;gap:16px;margin:8px 0 14px}
.risk-ring{--score:80;width:116px;height:116px;border-radius:50%;display:grid;place-items:center;position:relative;background:conic-gradient(var(--red) calc(var(--score)*1%),#1b2d44 0);font-family:Segoe UI,Arial,sans-serif;font-size:31px;font-weight:700;flex:0 0 auto}
.risk-ring:before{content:"";position:absolute;inset:10px;border-radius:50%;background:#0b1728}
.risk-ring span,.risk-ring small{position:relative;z-index:1}
.risk-ring small{font-size:10px;color:var(--muted);margin-left:-24px;margin-top:36px}
.risk-ring-wrap p{font-size:11px;color:var(--muted);line-height:1.5;margin:5px 0 0}
.factor-list{display:grid;gap:8px}
.factor-row{display:grid;grid-template-columns:1fr 46px;gap:10px;align-items:center;font-size:10px;color:var(--muted)}
.factor-row div{height:6px;border-radius:5px;background:#182a42;overflow:hidden;margin-top:4px}
.factor-row div i{display:block;height:100%;border-radius:inherit;background:linear-gradient(90deg,var(--cyan),var(--purple))}
.factor-row strong{color:#fff;text-align:right}
.text-btn{background:none;color:var(--cyan);border:0;padding:6px;font-size:11px}
.table-wrap{overflow:auto}
table{width:100%;border-collapse:collapse;font-size:11px}
th{text-align:left;color:#7890ad;text-transform:uppercase;letter-spacing:.8px;font-size:9px;padding:9px;border-bottom:1px solid var(--line)}
td{padding:10px 9px;border-bottom:1px solid rgba(28,48,75,.65);white-space:nowrap}
tbody tr:hover{background:rgba(51,214,255,.035)}
.risk-badge,.status-badge,.gravity-badge{display:inline-flex;padding:5px 7px;border-radius:7px;font-size:9px;font-weight:800}
.risk-badge.low{background:rgba(70,230,166,.1);color:var(--green)}
.risk-badge.medium{background:rgba(255,191,72,.1);color:var(--amber)}
.risk-badge.high{background:rgba(255,129,74,.11);color:var(--orange)}
.risk-badge.critical{background:rgba(255,77,109,.12);color:var(--red)}
.status-badge{background:rgba(51,214,255,.08);color:var(--cyan)}
.gravity-badge.heinous{background:rgba(255,77,109,.1);color:var(--red)}
.gravity-badge.non-heinous{background:rgba(70,230,166,.1);color:var(--green)}
.alert-count{min-width:30px;height:30px;border-radius:50%;display:grid;place-items:center;background:rgba(255,77,109,.12);color:var(--red);font-weight:800}
.alert-list{display:grid;gap:9px}
.alert-item{display:grid;grid-template-columns:32px 1fr;gap:10px;padding:10px;border-radius:11px;background:#091526;border:1px solid rgba(28,48,75,.7)}
.alert-icon{width:32px;height:32px;border-radius:9px;display:grid;place-items:center;background:rgba(255,129,74,.1);color:var(--orange)}
.alert-item strong{font-size:11px;display:block}
.alert-item p{font-size:9px;color:var(--muted);line-height:1.45;margin:3px 0 0}
.donut-layout{display:grid;grid-template-columns:260px 1fr;align-items:center}
.donut-legend{display:grid;gap:11px}
.donut-legend div{display:flex;justify-content:space-between;gap:20px;color:var(--muted);font-size:11px}
.donut-legend strong{color:#fff}

.map-layout{grid-template-columns:minmax(0,2fr) minmax(280px,.75fr)}
.map-panel{padding-bottom:10px}
.map-mode{display:flex;padding:3px;border:1px solid var(--line);border-radius:9px}
.mini-toggle{border:0;background:transparent;color:var(--muted);padding:6px 10px;font-size:10px}
.mini-toggle.active{background:rgba(51,214,255,.13);color:var(--cyan)}
.map-stage{position:relative;min-height:620px;display:grid;place-items:center;border-radius:14px;background:radial-gradient(circle at 50% 45%,rgba(51,214,255,.09),transparent 45%),#07111f;overflow:hidden}
#karnatakaMap{height:600px;max-width:100%}
.state-shape{fill:url(#mapGradient);stroke:#315375;stroke-width:3}
.map-marker{cursor:pointer;transition:.2s}
.map-marker:hover{filter:url(#glow)}
.map-marker circle:first-child{opacity:.2}
.map-marker text{fill:#dbeafe;font-size:10px;font-weight:800;pointer-events:none}
.map-tooltip{position:absolute;display:none;pointer-events:none;background:#020812;border:1px solid var(--line);padding:10px;border-radius:9px;font-size:10px;box-shadow:var(--shadow);z-index:4}
.map-tooltip strong{display:block;font-size:12px;margin-bottom:3px}
.map-legend{position:absolute;left:18px;bottom:16px;display:flex;gap:13px;padding:9px 11px;border:1px solid var(--line);background:rgba(5,11,20,.85);border-radius:9px;color:var(--muted);font-size:9px}
.map-legend i,.network-key i{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:4px}
.risk-low{background:var(--green)}.risk-medium{background:var(--amber)}.risk-high{background:var(--orange)}.risk-critical{background:var(--red)}
.map-side{display:grid;gap:14px;align-content:start}
.district-score{font-family:Segoe UI,Arial,sans-serif;font-size:72px;font-weight:700;line-height:1;color:var(--red);margin:15px 0}
.mini-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.mini-stat{background:#07111f;border:1px solid var(--line);padding:10px;border-radius:9px}
.mini-stat strong{font-size:16px;display:block}
.mini-stat span{font-size:9px;color:var(--muted)}
.recommendations{padding-left:18px;margin-bottom:0}
.recommendations li{padding:8px 0;color:var(--muted);font-size:10px;line-height:1.5;border-bottom:1px solid rgba(28,48,75,.5)}
.station-cards{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.station-card{padding:12px;border:1px solid var(--line);border-radius:11px;background:#081426}
.station-card strong{display:block;font-size:11px}
.station-card span{font-size:9px;color:var(--muted)}
.station-bar{height:5px;background:#1b2d44;border-radius:5px;margin:10px 0 6px;overflow:hidden}
.station-bar i{display:block;height:100%;background:linear-gradient(90deg,var(--cyan),var(--red))}

.funnel{display:grid;gap:10px;padding:10px 0}
.funnel-stage{height:54px;margin:auto;display:flex;align-items:center;justify-content:space-between;padding:0 16px;background:linear-gradient(90deg,rgba(51,214,255,.18),rgba(159,122,234,.13));border:1px solid rgba(51,214,255,.18);clip-path:polygon(3% 0,97% 0,100% 50%,97% 100%,3% 100%,0 50%)}
.funnel-stage strong{font-size:11px}.funnel-stage span{font-size:18px;font-family:Segoe UI,Arial,sans-serif;font-weight:700}
.priority{font-weight:800}.priority.critical{color:var(--red)}.priority.high{color:var(--orange)}
.row-action{background:rgba(51,214,255,.1);border:1px solid rgba(51,214,255,.2);color:var(--cyan);border-radius:7px;padding:5px 8px;font-size:9px}

.network-layout{grid-template-columns:minmax(0,2.2fr) minmax(280px,.8fr)}
.network-stage{position:relative;min-height:540px;background:radial-gradient(circle at center,rgba(51,214,255,.09),transparent 50%),#07111f;border-radius:13px;overflow:hidden}
#networkSvg{width:100%;height:540px}
.net-link{stroke:#2a4566;stroke-width:1.2}
.net-node{cursor:pointer}
.net-node text{fill:#dbeafe;font-size:10px;font-weight:700;text-anchor:middle;pointer-events:none}
.net-node circle{stroke-width:2;transition:.2s}
.net-node:hover circle{filter:url(#glow);transform-origin:center;transform:scale(1.08)}
.network-key{position:absolute;left:14px;bottom:14px;display:flex;gap:12px;color:var(--muted);font-size:9px;background:rgba(5,11,20,.85);border:1px solid var(--line);padding:8px 10px;border-radius:8px}
.node-repeat{background:var(--red)}.node-accused{background:var(--purple)}.node-case{background:var(--cyan)}
.network-side{display:grid;gap:14px;align-content:start}
.empty-state,.muted{color:var(--muted);font-size:11px;line-height:1.7}
.entity-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px}
.entity-grid div{background:#07111f;border:1px solid var(--line);padding:10px;border-radius:9px}
.entity-grid strong{display:block;font-size:15px}
.entity-grid span{font-size:9px;color:var(--muted)}

.case-head{align-items:center}
.search-box{display:flex;align-items:center;gap:7px;min-width:350px}
.search-box input{border:0;background:transparent;padding:8px}
.pagination{display:flex;align-items:center;justify-content:center;gap:15px;margin-top:14px}
.pagination button{background:#07111f;color:var(--text)}
.pagination span{font-size:10px;color:var(--muted)}

.ask-panel{position:fixed;bottom:18px;left:294px;right:30px;display:grid;grid-template-columns:42px auto minmax(250px,1fr) auto;gap:12px;align-items:center;padding:12px;border-radius:15px;background:rgba(7,17,31,.94);border:1px solid rgba(51,214,255,.35);box-shadow:0 20px 80px rgba(0,0,0,.55);backdrop-filter:blur(16px);z-index:9}
.ask-icon{width:40px;height:40px;border-radius:11px;display:grid;place-items:center;background:linear-gradient(135deg,var(--cyan),var(--purple));color:#02101a;font-size:20px}
.ask-copy strong{display:block;font-size:11px}.ask-copy span{display:block;color:var(--muted);font-size:9px}
#askBtn{border:0;border-radius:10px;padding:11px 17px;background:linear-gradient(135deg,var(--cyan),var(--cyan-2));font-weight:800;color:#02101a}

.modal-backdrop{position:fixed;inset:0;background:rgba(0,0,0,.72);display:none;place-items:center;padding:20px;z-index:30}
.modal-backdrop.open{display:grid}
.modal{position:relative;width:min(900px,96vw);max-height:90vh;overflow:auto;background:#07111f;border:1px solid #274463;border-radius:18px;padding:24px;box-shadow:0 30px 100px rgba(0,0,0,.7)}
.modal-close{position:absolute;right:15px;top:12px;border:0;background:transparent;color:var(--muted);font-size:28px}
.modal-title{font-family:Segoe UI,Arial,sans-serif;font-size:24px;margin-bottom:6px}
.modal-sub{color:var(--muted);font-size:11px}
.modal-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin:20px 0}
.modal-stat{background:#0b182a;border:1px solid var(--line);border-radius:10px;padding:12px}
.modal-stat span{display:block;color:var(--muted);font-size:9px}.modal-stat strong{font-size:12px}
.timeline{position:relative;display:grid;grid-template-columns:repeat(5,1fr);gap:10px;margin:25px 0}
.timeline:before{content:"";position:absolute;top:16px;left:8%;right:8%;height:2px;background:#24415f}
.timeline-step{position:relative;text-align:center}
.timeline-step i{position:relative;display:block;width:34px;height:34px;margin:0 auto 7px;border-radius:50%;background:#0b182a;border:2px solid var(--cyan);z-index:1}
.timeline-step.complete i{background:var(--cyan);box-shadow:0 0 18px rgba(51,214,255,.35)}
.timeline-step strong{display:block;font-size:9px}.timeline-step span{font-size:8px;color:var(--muted)}
.modal-columns{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.modal-section{background:#0b182a;border:1px solid var(--line);border-radius:12px;padding:14px}
.modal-section h3{font-size:12px;margin-bottom:10px}
.modal-list{display:grid;gap:8px;font-size:10px;color:var(--muted)}
.modal-list div{display:flex;justify-content:space-between;gap:15px}
.modal-list strong{color:#fff}
.toast{position:fixed;top:20px;right:20px;transform:translateY(-100px);opacity:0;transition:.25s;z-index:50;background:#0b182a;border:1px solid var(--cyan);padding:12px 16px;border-radius:10px;font-size:11px;box-shadow:var(--shadow)}
.toast.show{transform:none;opacity:1}

@media (max-width:1200px){
  .metric-grid{grid-template-columns:repeat(3,1fr)}
  .control-strip{grid-template-columns:repeat(2,1fr)}
  .data-badge{grid-column:span 2}
  .station-cards{grid-template-columns:repeat(2,1fr)}
}
@media (max-width:900px){
  .app-shell{display:block}
  .sidebar{position:relative;width:100%;height:auto}
  .nav{display:grid;grid-template-columns:repeat(2,1fr)}
  .sidebar-card,.privacy-note{display:none}
  .main{padding:20px 14px 130px}
  .two-one,.equal,.map-layout,.network-layout{grid-template-columns:1fr}
  .ask-panel{left:14px;right:14px;grid-template-columns:40px 1fr auto}
  .ask-copy{display:none}
  .donut-layout{grid-template-columns:1fr}
  .modal-grid{grid-template-columns:repeat(2,1fr)}
}
@media (max-width:600px){
  .topbar{align-items:flex-start}.top-actions .ghost-btn{display:none}
  .metric-grid{grid-template-columns:repeat(2,1fr)}
  .control-strip{grid-template-columns:1fr}.data-badge{grid-column:auto}
  .nav{grid-template-columns:1fr}
  .station-cards{grid-template-columns:1fr}
  .search-box{min-width:0;width:100%}.case-head{align-items:flex-start;flex-direction:column}
  .modal-columns,.timeline{grid-template-columns:1fr}
  .timeline:before{display:none}
}
